{
  "name": "experience-replay",
  "version": "0.1.1",
  "description": "OpenClaw plugin for contextual experience replay and self-improvement.",
  "type": "module",
  "main": "./dist/index.js",
  "keywords": [
    "openclaw-plugin",
    "openclaw",
    "experience-replay",
    "agent-memory"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "examples",
    "openclaw.plugin.json",
    "README.md",
    "README_ZH.md",
    "LICENSE"
  ],
  "bin": {
    "experience-replay": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.13"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "openclaw": "2026.3.13",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
